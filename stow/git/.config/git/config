# Ensure dotfiles repo configured correctly, even on work computer
# git -C ~/dotfiles config --local user.name "Your Name"
# git -C ~/dotfiles config --local user.email "you@example.com"
# See `~/dotfiles/README.md`

[branch]
    sort = -committerdate # recently commited branches listed first

[column]
    ui = auto # display branch/tag lists in columns

[commit]
    verbose = true # show diff in commit message editor

[core]
    editor = /usr/bin/vi # edit commits in vi
    hooksPath = ~/.config/git/hooks # stowed from dotfile

[diff]
    algorithm = histogram # more readable
    colorMoved = plain # highlight moved lines in different color
    renames = true # detect renames in diff

[fetch]
    prune = true # fetch drops local branch that no longer exists
    pruneTags = true # fetch drops local tags that no longer exist
    all = true # fethc from all remotes, not just origin

[help]
    autocorrect = prompt # asks before auto-correcting cmd typos

[init]
    defaultBranch = main # Default of GitHub/GitLab

[merge]
    conflictStyle = zdiff3 # add base text between conflict markers

[pull]
    rebase = true # replay local commits on top of fetched commits

[push]
    autoSetupRemote = true # create upstream on first push
    followTags = true # push commits and tags at same time

[rebase]
    autoSquash = true # auto-reorder fixup/squash commits during rebase
    autoStash = true # stach changes before rebase, restore after
    updateRefs = true # rebase one branch updates others

[rerere]
    enabled = true # auto-reply redundant conflic resolutions
    autoupdate = true # auto-stage file after conflict resolution

[tag]
    sort = version:refname # sort semantically (v1.9 < v.1.10)
